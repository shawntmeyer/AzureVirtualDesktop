{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "artifactsUri": {
      "type": "string"
    },
    "fileUris": {
      "type": "array"
    },
    "location": {
      "type": "string"
    },
    "scriptToRun": {
      "type": "string"
    },
    "scriptArguments": {
      "type": "string"
    },
    "userAssignedIdentityClientId": {
      "type": "string"
    },
    "vmname": {
      "type": "string"
    },
    "timeStamp": {
      "type": "string",
      "defaultValue": "[utcNow('yyyyMMddhhmmss')]"
    }
  },
  "variables": {
    "copy": [
      {
        "name": "cseUris",
        "count": "[length(parameters('fileUris'))]",
        "input": "[if(not(contains(parameters('fileUris')[copyIndex('cseUris')], '/')), format('{0}{1}', variables('baseUri'), parameters('fileUris')[copyIndex('cseUris')]), parameters('fileUris')[copyIndex('cseUris')])]"
      }
    ],
    "baseUri": "[if(equals(last(parameters('artifactsUri')), '/'), parameters('artifactsUri'), format('{0}/', parameters('artifactsUri')))]",
    "baseCommand": "[format('powershell -ExecutionPolicy Unrestricted -Command .\\{0}', parameters('scriptToRun'))]",
    "commandToExecute": "[if(not(empty(parameters('scriptArguments'))), format('{0} {1}', variables('baseCommand'), parameters('scriptArguments')), variables('baseCommand'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2021-03-01",
      "name": "[format('{0}/{1}', parameters('vmname'), 'CustomScriptExtension')]",
      "location": "[parameters('location')]",
      "tags": {},
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "timeStamp": "[parameters('timeStamp')]"
        },
        "protectedSettings": {
          "commandToExecute": "[variables('commandToExecute')]",
          "fileUris": "[variables('cseUris')]",
          "managedIdentity": "[if(not(empty(parameters('userAssignedIdentityClientId'))), createObject('clientId', parameters('userAssignedIdentityClientId')), createObject())]"
        }
      }
    }
  ]
}